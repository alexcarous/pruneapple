#!/bin/sh
# pre-push hook

echo "========================================="
echo "Running Local CI before push..."
echo "========================================="

# Run the test suite
echo "Running make test..."
if ! make test; then
    echo "========================================="
    echo "❌ Local CI Failed: Tests did not pass."
    echo "Please fix the failing tests before pushing."
    echo "========================================="
    exit 1
fi

echo "========================================="
echo "✅ Local CI Passed. Proceeding with push."
echo "========================================="
exit 0
