#!/bin/sh
# pre-push hook

export PATH="/opt/homebrew/bin:/usr/local/bin:$HOME/.local/bin:$PATH"

echo "========================================="
echo "Running Local CI before push..."
echo "========================================="

CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)
TEST_COMMAND="mise exec -- tuist test"

# Force a clean test run without cache only when pushing to main
# to save developer time on feature branches.
if [ "$CURRENT_BRANCH" = "main" ]; then
    echo "Pushing to main branch. Disabling Tuist cache..."
    TEST_COMMAND="mise exec -- tuist test --no-binary-cache"
fi

echo "Running $TEST_COMMAND..."
if ! $TEST_COMMAND; then
    echo "========================================="
    echo "❌ Local CI Failed: Tests did not pass."
    echo "Please fix the failing tests before pushing."
    echo "========================================="
    exit 1
fi

echo "========================================="
echo "✅ Local CI Passed. Proceeding with push."
echo "========================================="
exit 0
