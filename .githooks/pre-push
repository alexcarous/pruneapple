#!/bin/sh
# pre-push hook

echo "========================================="
echo "Running Local CI before push..."
echo "========================================="

# Run the test suite without caching to avoid stale passes
echo "Running tuist test --no-cache..."
if ! mise exec -- tuist test --no-cache; then
    echo "========================================="
    echo "❌ Local CI Failed: Tests did not pass."
    echo "Please fix the failing tests before pushing."
    echo "========================================="
    exit 1
fi

echo "========================================="
echo "✅ Local CI Passed. Proceeding with push."
echo "========================================="
exit 0
